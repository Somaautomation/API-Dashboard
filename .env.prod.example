# -------- Deployment metadata --------
DEPLOY_TAG=latest
BACKEND_IMAGE=ghcr.io/your-org/apidashboard-backend
FRONTEND_IMAGE=ghcr.io/your-org/apidashboard-frontend
INTERNAL_DOMAIN=api-dashboard.yourcompany.com
LETSENCRYPT_EMAIL=devops@company.com
ALLOWED_CIDRS=0.0.0.0/0

# -------- Edge access policy --------
# For public access keep ALLOWED_CIDRS=0.0.0.0/0.
# For restricted access, set ALLOWED_CIDRS to office/VPN CIDRs.

# -------- Postgres container --------
POSTGRES_USER=zpe
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=zpe_api_platform

# -------- App --------
APP_NAME=ZPE API Testing Platform
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=replace-with-64-char-random-value
APP_ENCRYPTION_KEY=replace-with-valid-fernet-key

# -------- API --------
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=https://api-dashboard.yourcompany.com

# -------- Auth --------
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14

# -------- Database --------
DATABASE_URL=postgresql+asyncpg://zpe:change-this-db-password@postgres:5432/zpe_api_platform
DATABASE_SYNC_URL=postgresql+psycopg://zpe:change-this-db-password@postgres:5432/zpe_api_platform

# -------- Redis --------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -------- Bootstrap admin --------
BOOTSTRAP_ADMIN_EMAIL=admin@company.com
BOOTSTRAP_ADMIN_PASSWORD=replace-this-immediately

# -------- AI provider (optional) --------
AI_PROVIDER=disabled
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
