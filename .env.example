# ---- App ----
APP_NAME=ZPE API Testing Platform
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production-please-32chars
APP_ENCRYPTION_KEY=base64-fernet-key-generate-with-python

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Auth ----
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://zpe:zpe@postgres:5432/zpe_api_platform
DATABASE_SYNC_URL=postgresql+psycopg://zpe:zpe@postgres:5432/zpe_api_platform

# ---- Redis ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Bootstrap admin ----
BOOTSTRAP_ADMIN_EMAIL=admin@zpesystems.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!123

# ---- AI provider (optional) ----
AI_PROVIDER=openai            # openai | azure | disabled
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Frontend ----
VITE_API_BASE_URL=https://api.qa-zpecloud.com/api/v1
